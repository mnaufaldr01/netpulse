# PostgreSQL (RDS on EC2; use 127.0.0.1:15432 when tunneling from laptop)
POSTGRES_HOST=<rds-endpoint>
POSTGRES_PORT=5432
POSTGRES_DB=netpulse
POSTGRES_USER=netpulse
POSTGRES_PASSWORD=<from SSM /netpulse/db_password — do not commit>

# AWS S3 data lake — leave S3_ENDPOINT_URL unset for real S3
S3_BUCKET=<terraform output s3_bucket_name>
AWS_DEFAULT_REGION=ap-southeast-2

# Local data paths on EC2
BOUNDARIES_DATA_PATH=/opt/netpulse/data/boundaries
OPENCELLID_DATA_PATH=/opt/netpulse/data/opencellid

# Pipeline constants (portfolio demo)
TOWER_SAMPLE_SIZE=100
RANDOM_SEED=42
BACKFILL_DAYS=35
SUBSCRIBER_COUNT=50000

# Airflow (Docker Compose on EC2)
AIRFLOW__CORE__LOAD_EXAMPLES=False
AIRFLOW__CORE__FERNET_KEY=<generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())">
AIRFLOW_UID=50000
_AIRFLOW_WWW_USER_USERNAME=airflow
_AIRFLOW_WWW_USER_PASSWORD=airflow

# Laptop Streamlit via SSM tunnel (override POSTGRES_HOST/PORT):
# POSTGRES_HOST=127.0.0.1
# POSTGRES_PORT=15432
