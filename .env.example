# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=netpulse
POSTGRES_USER=netpulse
POSTGRES_PASSWORD=netpulse_dev

# MinIO (S3-compatible) — unset S3_ENDPOINT_URL in cloud for real AWS S3
S3_ENDPOINT_URL=http://localhost:9000
S3_BUCKET=netpulse-lake
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_DEFAULT_REGION=us-east-1

# Local data paths (gitignored)
OPENCELLID_DATA_PATH=./data/opencellid
BOUNDARIES_DATA_PATH=./data/boundaries

# Pipeline constants
TOWER_SAMPLE_SIZE=100
RANDOM_SEED=42
BACKFILL_DAYS=35
SUBSCRIBER_COUNT=50000

# Airflow (Docker Compose)
AIRFLOW__CORE__LOAD_EXAMPLES=False
AIRFLOW_UID=50000
_AIRFLOW_WWW_USER_USERNAME=airflow
_AIRFLOW_WWW_USER_PASSWORD=airflow

# MinIO root credentials (Docker Compose)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
